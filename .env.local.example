# ─────────────────────────────────────────────────────────────────────────────
# AI Skill Assessment & Talent Development Platform
# Environment Variables (copy to .env.local and fill in values)
# ─────────────────────────────────────────────────────────────────────────────

# API Gateway base URL (e.g., https://xxxxxxxx.execute-api.ap-southeast-3.amazonaws.com/prod)
NEXT_PUBLIC_API_URL=

# Amazon Cognito User Pool configuration
NEXT_PUBLIC_USER_POOL_ID=
NEXT_PUBLIC_USER_POOL_CLIENT_ID=

# (Optional) Cognito Identity Pool ID for federated access
NEXT_PUBLIC_IDENTITY_POOL_ID=
